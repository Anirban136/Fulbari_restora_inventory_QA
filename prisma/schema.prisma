generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String            @id @default(cuid())
  name           String
  email          String?           @unique
  pin            String            @unique
  role           String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  Dispatches     InventoryLedger[]
  Tabs           Tab[]
  VendorPayments VendorPayment[]
}

model Outlet {
  id        String            @id @default(cuid())
  name      String
  type      String
  createdAt DateTime          @default(now())
  Ledger    InventoryLedger[]
  Menus     MenuItem[]
  Stock     OutletStock[]
  Tabs      Tab[]
}

model Vendor {
  id        String            @id @default(cuid())
  name      String
  contact   String?
  email     String?
  address   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  Ledger    InventoryLedger[]
  Payments  VendorPayment[]
}

model VendorPayment {
  id        String   @id @default(cuid())
  vendorId  String
  amount    Float
  notes     String?
  paidBy    String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [paidBy], references: [id])
  Vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Item {
  id           String               @id @default(cuid())
  name         String
  category     String               @default("Uncategorized")
  unit         String
  currentStock Float                @default(0)
  costPerUnit  Float?
  sellPrice    Float?
  minStock     Float                @default(0)
  piecesPerBox Int?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  Ledger       InventoryLedger[]
  MenuItems    MenuItem[]
  ingredients  MenuItemIngredient[]
  OutletStock  OutletStock[]
}

model InventoryLedger {
  id        String   @id @default(cuid())
  type      String
  itemId    String
  quantity  Float
  outletId  String?
  vendorId  String?
  userId    String
  notes     String?
  createdAt DateTime @default(now())
  Item      Item     @relation(fields: [itemId], references: [id])
  Outlet    Outlet?  @relation(fields: [outletId], references: [id])
  User      User     @relation(fields: [userId], references: [id])
  Vendor    Vendor?  @relation(fields: [vendorId], references: [id])
}

model OutletStock {
  id        String   @id @default(cuid())
  outletId  String
  itemId    String
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt
  Item      Item     @relation(fields: [itemId], references: [id])
  Outlet    Outlet   @relation(fields: [outletId], references: [id])

  @@unique([outletId, itemId])
}

model MenuItem {
  id          String               @id @default(cuid())
  outletId    String
  name        String
  price       Float
  categoryId  String?
  isAvailable Boolean              @default(true)
  itemId      String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  Item        Item?                @relation(fields: [itemId], references: [id])
  Outlet      Outlet               @relation(fields: [outletId], references: [id])
  ingredients MenuItemIngredient[]
  TabItems    TabItem[]
}

model MenuItemIngredient {
  id         String   @id @default(cuid())
  menuItemId String
  itemId     String
  quantity   Float
  Item       Item     @relation(fields: [itemId], references: [id])
  MenuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model Tab {
  id                String    @id @default(cuid())
  outletId          String
  userId            String
  customerName      String?
  tableName         String?
  tokenNumber       Int?
  status            String
  totalAmount       Float     @default(0)
  paymentMode       String?
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  splitCashAmount   Float?
  splitOnlineAmount Float?
  totalPaid         Float     @default(0)
  Outlet            Outlet    @relation(fields: [outletId], references: [id])
  User              User      @relation(fields: [userId], references: [id])
  Items             TabItem[]
}

model TabItem {
  id          String   @id @default(cuid())
  tabId       String
  menuItemId  String
  quantity    Int      @default(1)
  priceAtTime Float
  addedAt     DateTime @default(now())
  isPaid      Boolean  @default(false)
  MenuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  Tab         Tab      @relation(fields: [tabId], references: [id])
}

model daily_transaction_snapshot {
  day               DateTime @id @db.Date
  total_cash        Decimal  @default(0) @db.Decimal(18, 2)
  total_card_upi    Decimal  @default(0) @db.Decimal(18, 2)
  total_amount      Decimal  @default(0) @db.Decimal(18, 2)
  last_refreshed_at DateTime @default(now()) @db.Timestamptz(6)
}
