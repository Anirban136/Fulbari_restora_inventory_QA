# ============================================================
#  QA ENVIRONMENT — Fulbari Restora Inventory
# ============================================================
#  This file is a TEMPLATE only. Copy it to .env.qa and fill
#  in the actual QA Supabase credentials.
#
#  IMPORTANT: .env.qa is in .gitignore — NEVER commit secrets.
#  All production values live in the PRODUCTION Vercel project.
#  All QA values go into the QA Vercel project environment.
# ============================================================

# ------ DATABASE (QA Supabase Project) ----------------------
# Get these from: Supabase Dashboard → Settings → Database → Connection Strings

# Transaction mode URL (port 6543) — used by Prisma at runtime
DATABASE_URL="postgresql://postgres.<QA_PROJECT_REF>:<QA_DB_PASSWORD>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session mode URL (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://postgres.<QA_PROJECT_REF>:<QA_DB_PASSWORD>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ------ NEXTAUTH -----------------------------------------------
# Use a DIFFERENT secret than production to ensure session isolation
NEXTAUTH_SECRET="fulbari-qa-secret-key-change-me"

# The deployed QA Vercel URL (no trailing slash)
NEXTAUTH_URL="https://<YOUR-QA-VERCEL-URL>.vercel.app"

# ------ SUPABASE CLIENT (QA Project) ---------------------------
# Get these from: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL="https://<QA_PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<QA_ANON_KEY>"
SUPABASE_SERVICE_ROLE_KEY="<QA_SERVICE_ROLE_KEY>"

# ------ NOTES --------------------------------------------------
# After adding these to your QA Vercel project, run:
#   1. npx prisma migrate deploy   (applies DB schema to QA DB)
#   2. node seed-users.mjs         (creates staff users in QA DB)
# Or visit: https://<YOUR-QA-VERCEL-URL>.vercel.app/api/seed
